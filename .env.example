# Database
DB_PASSWORD=change_me_strong_password

# JWT — generate with: openssl rand -hex 64
JWT_SECRET=change_me_generate_with_openssl

# CORS — the origin Traefik forwards from (the server IP or domain)
CORS_ORIGIN=https://humerez.dev

# Base path — must match the Traefik PathPrefix (with trailing slash)
VITE_BASE_PATH=/receipts/

# API URL — base path prefix for API calls (no trailing slash)
VITE_API_URL=/receipts

# Webhook — auto-deploy on push. Generate with: openssl rand -hex 32
WEBHOOK_SECRET=change_me_generate_with_openssl
WEBHOOK_PORT=9000
WEBHOOK_BRANCH=main
